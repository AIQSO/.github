{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "description": "AIQSO org-wide Renovate config — copy to AIQSO/.github repo as renovate.json",
  "extends": [
    "config:recommended",
    ":dependencyDashboard",
    ":semanticCommits",
    ":automergeMinor",
    "group:allNonMajor"
  ],
  "schedule": ["before 9am on monday"],
  "timezone": "America/Chicago",
  "labels": ["dependencies", "renovate"],
  "prHourlyLimit": 5,
  "prConcurrentLimit": 10,
  "platformAutomerge": true,
  "packageRules": [
    {
      "description": "Automerge patch updates with passing CI",
      "matchUpdateTypes": ["patch"],
      "automerge": true,
      "automergeType": "pr",
      "requiredStatusChecks": ["DevSecOps"]
    },
    {
      "description": "Auto-PR for minor updates (manual merge)",
      "matchUpdateTypes": ["minor"],
      "automerge": false
    },
    {
      "description": "Manual review required for major updates",
      "matchUpdateTypes": ["major"],
      "automerge": false,
      "labels": ["dependencies", "renovate", "major-update"],
      "prPriority": 10
    },
    {
      "description": "Group all security updates together",
      "matchCategories": ["security"],
      "groupName": "security updates",
      "groupSlug": "security",
      "automerge": true,
      "requiredStatusChecks": ["DevSecOps"],
      "prPriority": 20,
      "labels": ["dependencies", "renovate", "security"]
    },
    {
      "description": "Group GitHub Actions updates",
      "matchManagers": ["github-actions"],
      "groupName": "github-actions",
      "automerge": true
    },
    {
      "description": "Pin Docker digests for security",
      "matchDatasources": ["docker"],
      "pinDigests": true
    },
    {
      "description": "Node.js: group non-major",
      "matchPackagePatterns": ["*"],
      "matchManagers": ["npm"],
      "matchUpdateTypes": ["patch", "minor"],
      "groupName": "npm non-major",
      "groupSlug": "npm-non-major"
    },
    {
      "description": "Python: group non-major",
      "matchPackagePatterns": ["*"],
      "matchManagers": ["pip_requirements", "pip_setup", "pipenv", "pyproject"],
      "matchUpdateTypes": ["patch", "minor"],
      "groupName": "python non-major",
      "groupSlug": "python-non-major"
    }
  ],
  "vulnerabilityAlerts": {
    "enabled": true,
    "labels": ["security", "vulnerability"],
    "automerge": true,
    "requiredStatusChecks": ["DevSecOps"]
  }
}
